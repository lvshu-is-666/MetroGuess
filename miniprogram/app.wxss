page {
  --primary-color: #4F46E5;
  --primary-light: #818CF8;
  --primary-dark: #3730A3;
  --success-color: #10B981;
  --warning-color: #F97316;
  --hint-color: #8B5CF6;
  --error-color: #EF4444;
  --cta-color: #F97316;
  --bg-color: #EEF2FF;
  --text-color: #1E1B4B;
  --transition-fast: 0.15s ease-out;
  --transition-normal: 0.25s ease-out;
  --shadow-sm: 0 8rpx 24rpx;
  --shadow-glow: 0 0 40rpx;
  --radius-lg: 1.5rem;
  --radius-xl: 2rem;

  --clay-bg: linear-gradient(145deg, rgba(255, 255, 255, 0.95) 0%, rgba(238, 242, 255, 0.9) 100%);
  --clay-border: 6rpx solid rgba(129, 140, 248, 0.25);
  --clay-shadow: 0 8rpx 0 rgba(129, 140, 248, 0.15), 0 16rpx 48rpx rgba(79, 70, 229, 0.12), inset 0 2rpx 0 rgba(255, 255, 255, 0.8);
  --clay-shadow-hover: 0 12rpx 0 rgba(129, 140, 248, 0.2), 0 32rpx 80rpx rgba(79, 70, 229, 0.18), inset 0 2rpx 0 rgba(255, 255, 255, 0.9);
  --clay-radius: 40rpx;

  --btn-bg: linear-gradient(145deg, #ffffff 0%, #f1f5f9 100%);
  --btn-border: 6rpx solid rgba(129, 140, 248, 0.3);
  --btn-shadow: 0 6rpx 0 rgba(129, 140, 248, 0.2), 0 8rpx 24rpx rgba(79, 70, 229, 0.1);
  --btn-shadow-hover: 0 8rpx 0 rgba(129, 140, 248, 0.25), 0 16rpx 40rpx rgba(79, 70, 229, 0.15);
  --btn-shadow-active: 0 2rpx 0 rgba(129, 140, 248, 0.15), 0 4rpx 12rpx rgba(79, 70, 229, 0.08);
  --btn-radius: 28rpx;

  --input-bg: linear-gradient(145deg, #ffffff 0%, #f8fafc 100%);
  --input-border: 6rpx solid rgba(129, 140, 248, 0.25);
  --input-shadow: 0 4rpx 0 rgba(129, 140, 248, 0.15), inset 0 2rpx 0 rgba(255, 255, 255, 0.8);
  --input-shadow-focus: 0 4rpx 0 rgba(79, 70, 229, 0.2), 0 0 0 8rpx rgba(79, 70, 229, 0.1);
  --input-radius: 24rpx;

  background: linear-gradient(135deg, #EEF2FF 0%, #E0E7FF 50%, #C7D2FE 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  color: var(--text-color);
  font-size: 28rpx;
  line-height: 1.5;
}

.container {
  min-height: 100vh;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.page-title {
  font-family: -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 56rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 32rpx;
  background: linear-gradient(135deg, #1E1B4B 0%, #4F46E5 50%, #6366F1 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.game-card {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(238, 242, 255, 0.9) 100%);
  border: 4rpx solid rgba(129, 140, 248, 0.4);
  border-radius: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(79, 70, 229, 0.08);
  padding: 32rpx;
  margin-bottom: 24rpx;
  transition: all 0.25s ease;
}

.game-card:hover {
  border-color: var(--primary-light);
  box-shadow: 0 16rpx 64rpx rgba(79, 70, 229, 0.2), 0 0 40rpx rgba(129, 140, 248, 0.3);
  transform: translateY(-4rpx);
}

.game-card.solved {
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.15) 0%, rgba(16, 185, 129, 0.1) 100%);
  border-color: var(--success-color);
  box-shadow: 0 0 40rpx rgba(16, 185, 129, 0.3);
}

.clay-card {
  background: var(--clay-bg);
  border: var(--clay-border);
  border-radius: var(--clay-radius);
  box-shadow: var(--clay-shadow);
  padding: 32rpx;
  margin-bottom: 24rpx;
  transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.clay-card:active {
  transform: translateY(-2rpx) scale(1.01);
  box-shadow: var(--clay-shadow-hover);
  border-color: rgba(129, 140, 248, 0.4);
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-light) 100%);
  color: white;
  border-radius: 24rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(79, 70, 229, 0.3);
  border: none;
  transition: all 0.15s ease-out;
}

.btn-primary:active {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 40rpx rgba(79, 70, 229, 0.4), 0 0 60rpx rgba(129, 140, 248, 0.3);
}

.btn-secondary {
  background: linear-gradient(135deg, var(--cta-color) 0%, #FB923C 100%);
  color: white;
  border-radius: 24rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(249, 115, 22, 0.3);
  border: none;
  transition: all 0.15s ease-out;
}

.btn-secondary:active {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 40rpx rgba(249, 115, 22, 0.4), 0 0 60rpx rgba(251, 146, 60, 0.3);
}

.btn-hint {
  background: linear-gradient(135deg, var(--hint-color) 0%, #A78BFA 100%);
  color: white;
  border-radius: 24rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(139, 92, 246, 0.3);
  border: none;
  transition: all 0.15s ease-out;
}

.btn-hint:active {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 40rpx rgba(139, 92, 246, 0.4), 0 0 60rpx rgba(167, 139, 250, 0.3);
}

.clay-btn {
  background: var(--btn-bg);
  border: var(--btn-border);
  border-radius: var(--btn-radius);
  box-shadow: var(--btn-shadow);
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  color: var(--text-color);
  transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.clay-btn:active {
  transform: translateY(2rpx);
  box-shadow: var(--btn-shadow-active);
}

.clay-btn.primary {
  background: linear-gradient(145deg, #4F46E5 0%, #6366F1 100%);
  color: white;
  border-color: transparent;
  box-shadow: 0 6rpx 0 #3730A3, 0 12rpx 32rpx rgba(79, 70, 229, 0.35);
}

.clay-btn.secondary {
  background: linear-gradient(145deg, #F97316 0%, #FB923C 100%);
  color: white;
  border-color: transparent;
  box-shadow: 0 6rpx 0 #C2410C, 0 12rpx 32rpx rgba(249, 115, 22, 0.35);
}

.clay-btn.danger {
  background: linear-gradient(145deg, #ef4444 0%, #f87171 100%);
  color: white;
  border-color: transparent;
  box-shadow: 0 6rpx 0 #dc2626, 0 12rpx 32rpx rgba(239, 68, 68, 0.35);
}

.mode-btn, .difficulty-btn {
  background-color: rgba(255, 255, 255, 0.9);
  border: 4rpx solid rgba(129, 140, 248, 0.3);
  border-radius: 24rpx;
  padding: 20rpx 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-color);
  box-shadow: 0 4rpx 16rpx rgba(79, 70, 229, 0.08);
  margin: 8rpx;
  transition: all 0.25s ease-out;
}

.mode-btn:active, .difficulty-btn:active {
  background-color: rgba(238, 242, 255, 0.95);
  border-color: var(--primary-light);
  box-shadow: 0 8rpx 32rpx rgba(79, 70, 229, 0.15);
}

.mode-btn.active {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-light) 100%);
  color: white;
  border-color: transparent;
  box-shadow: 0 8rpx 32rpx rgba(79, 70, 229, 0.3), 0 0 40rpx rgba(129, 140, 248, 0.2);
}

.difficulty-btn.active {
  background: linear-gradient(135deg, #059669 0%, #10B981 100%);
  color: white;
  border-color: transparent;
  box-shadow: 0 8rpx 32rpx rgba(16, 185, 129, 0.3), 0 0 40rpx rgba(16, 185, 129, 0.2);
}

.clay-input {
  background: var(--input-bg);
  border: var(--input-border);
  border-radius: var(--input-radius);
  box-shadow: var(--input-shadow);
  padding: 24rpx 32rpx;
  font-size: 30rpx;
  color: var(--text-color);
  width: 100%;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.clay-input:focus {
  border-color: var(--primary-color);
  box-shadow: var(--input-shadow-focus);
}

.stat-box {
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.9) 0%, rgba(248, 250, 252, 0.8) 100%);
  border: 4rpx solid rgba(129, 140, 248, 0.2);
  border-radius: 32rpx;
  padding: 24rpx 32rpx;
  text-align: center;
  box-shadow: 0 4rpx 0 rgba(129, 140, 248, 0.1), 0 8rpx 24rpx rgba(79, 70, 229, 0.08);
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1;
  color: var(--primary-color);
}

.stat-label {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 8rpx;
  font-weight: 500;
}

.letter-key {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #ffffff 0%, #f1f5f9 100%);
  border: 4rpx solid rgba(129, 140, 248, 0.3);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 0 rgba(129, 140, 248, 0.2), 0 6rpx 16rpx rgba(79, 70, 229, 0.1);
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-color);
  margin: 6rpx;
  transition: all 0.15s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.letter-key:active {
  transform: translateY(-4rpx) scale(1.05);
  box-shadow: 0 6rpx 0 rgba(129, 140, 248, 0.25), 0 12rpx 24rpx rgba(79, 70, 229, 0.15);
}

.letter-key.used {
  opacity: 0.5;
}

.letter-key.found {
  background: linear-gradient(145deg, #22c55e 0%, #4ade80 100%);
  border-color: #16a34a;
  color: white;
  box-shadow: 0 4rpx 0 #16a34a, 0 8rpx 24rpx rgba(34, 197, 94, 0.3);
}

.letter-key.not-found {
  background: linear-gradient(145deg, #ef4444 0%, #f87171 100%);
  border-color: #dc2626;
  color: white;
  box-shadow: 0 4rpx 0 #dc2626, 0 8rpx 24rpx rgba(239, 68, 68, 0.3);
}

.progress-container {
  background: rgba(129, 140, 248, 0.15);
  border-radius: 9999rpx;
  height: 20rpx;
  overflow: hidden;
  box-shadow: inset 0 4rpx 8rpx rgba(0, 0, 0, 0.05);
}

.progress-fill {
  background: linear-gradient(90deg, #4F46E5, #818CF8, #A78BFA);
  border-radius: 9999rpx;
  height: 100%;
  transition: width 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 0 0 20rpx rgba(79, 70, 229, 0.4);
}

.quiz-card {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.98) 0%, rgba(238, 242, 255, 0.95) 100%);
  border: 4rpx solid rgba(129, 140, 248, 0.4);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  transition: all 0.25s ease;
}

.quiz-card:active {
  transform: scale(0.98);
  border-color: var(--primary-light);
  box-shadow: 0 16rpx 64rpx rgba(79, 70, 229, 0.2);
}

.quiz-card-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 16rpx;
}

.quiz-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 9999rpx;
  font-size: 24rpx;
  font-weight: 500;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.quiz-tag-difficulty-easy {
  background: #dcfce7;
  color: #166534;
}

.quiz-tag-difficulty-normal {
  background: #fef3c7;
  color: #92400e;
}

.quiz-tag-difficulty-hard {
  background: #fee2e2;
  color: #991b1b;
}

.quiz-tag-city {
  background: #e0e7ff;
  color: #3730a3;
}

.quiz-tag-count {
  background: #f1f5f9;
  color: #475569;
}

.letter-display {
  font-family: 'Courier New', monospace;
  letter-spacing: 0.15em;
  font-size: 36rpx;
  font-weight: 600;
}

.letter-reveal {
  color: var(--primary-color);
  animation: popIn 0.3s ease-out;
}

.empty-state {
  text-align: center;
  padding: 96rpx 48rpx;
  color: #64748b;
}

.empty-state-icon {
  width: 128rpx;
  height: 128rpx;
  margin: 0 auto 32rpx;
  opacity: 0.5;
}

.empty-state-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #475569;
  margin-bottom: 16rpx;
}

.empty-state-desc {
  font-size: 28rpx;
}

.loading-spinner {
  display: inline-block;
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(129, 140, 248, 0.3);
  border-radius: 50%;
  border-top-color: var(--primary-color);
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes popIn {
  0% { transform: scale(0.5); opacity: 0; }
  50% { transform: scale(1.15); }
  100% { transform: scale(1); opacity: 1; }
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  20%, 60% { transform: translateX(-10rpx); }
  40%, 80% { transform: translateX(10rpx); }
}

@keyframes pulseSuccess {
  0% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.7); }
  70% { box-shadow: 0 0 0 30rpx rgba(34, 197, 94, 0); }
  100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0); }
}

.animate-fade-in-up {
  animation: fadeInUp 0.5s ease-out forwards;
}

.animate-pop-in {
  animation: popIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

.shake {
  animation: shake 0.5s ease;
}

.pulse-success {
  animation: pulseSuccess 0.5s ease;
}

.hidden {
  display: none !important;
}

.flex {
  display: flex;
}

.flex-col {
  flex-direction: column;
}

.flex-row {
  flex-direction: row;
}

.items-center {
  align-items: center;
}

.justify-center {
  justify-content: center;
}

.justify-between {
  justify-content: space-between;
}

.gap-2 {
  gap: 16rpx;
}

.gap-3 {
  gap: 24rpx;
}

.gap-4 {
  gap: 32rpx;
}

.p-4 {
  padding: 32rpx;
}

.mt-2 {
  margin-top: 16rpx;
}

.mt-3 {
  margin-top: 24rpx;
}

.mt-4 {
  margin-top: 32rpx;
}

.mb-2 {
  margin-bottom: 16rpx;
}

.mb-3 {
  margin-bottom: 24rpx;
}

.mb-4 {
  margin-bottom: 32rpx;
}

.text-center {
  text-align: center;
}

.text-sm {
  font-size: 24rpx;
}

.text-base {
  font-size: 28rpx;
}

.text-lg {
  font-size: 32rpx;
}

.text-xl {
  font-size: 36rpx;
}

.text-2xl {
  font-size: 48rpx;
}

.font-bold {
  font-weight: 700;
}

.font-semibold {
  font-weight: 600;
}

.text-slate-500 {
  color: #64748b;
}

.text-slate-600 {
  color: #475569;
}

.text-slate-700 {
  color: #334155;
}

.text-slate-800 {
  color: #1e293b;
}

.text-slate-900 {
  color: #0f172a;
}

.bg-white {
  background-color: #ffffff;
}

.bg-slate-50 {
  background-color: #f8fafc;
}

.bg-slate-100 {
  background-color: #f1f5f9;
}

.rounded-lg {
  border-radius: 16rpx;
}

.rounded-xl {
  border-radius: 24rpx;
}

.rounded-2xl {
  border-radius: 32rpx;
}

.shadow {
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.shadow-lg {
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
}

.w-full {
  width: 100%;
}

.h-full {
  height: 100%;
}

.overflow-hidden {
  overflow: hidden;
}

.overflow-auto {
  overflow: auto;
}

.dark {
  --clay-bg: linear-gradient(145deg, rgba(30, 41, 59, 0.95) 0%, rgba(51, 65, 85, 0.9) 100%);
  --clay-border: 6rpx solid rgba(71, 85, 105, 0.4);
  --clay-shadow: 0 8rpx 0 rgba(0, 0, 0, 0.3), 0 16rpx 48rpx rgba(0, 0, 0, 0.3);
  --clay-shadow-hover: 0 12rpx 0 rgba(0, 0, 0, 0.35), 0 32rpx 80rpx rgba(0, 0, 0, 0.4);
  --btn-bg: linear-gradient(145deg, #334155 0%, #1e293b 100%);
  --btn-border: 6rpx solid rgba(71, 85, 105, 0.5);
  --input-bg: linear-gradient(145deg, #334155 0%, #1e293b 100%);
  --input-border: 6rpx solid rgba(71, 85, 105, 0.5);
}

.dark page {
  background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #1e293b 100%);
  color: #f1f5f9;
}

.dark .game-card {
  background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
  border-color: #475569;
}

.dark .game-card:hover {
  border-color: #60a5fa;
  box-shadow: 0 8rpx 40rpx rgba(96, 165, 250, 0.2);
}

.dark .game-card.solved {
  background: linear-gradient(135deg, #14532d 0%, #166534 100%);
  border-color: var(--success-color);
}

.dark .page-title {
  background: linear-gradient(135deg, #f1f5f9 0%, #a5b4fc 100%);
  -webkit-background-clip: text;
  background-clip: text;
}

.dark .stat-box {
  background: linear-gradient(145deg, rgba(51, 65, 85, 0.9) 0%, rgba(30, 41, 59, 0.8) 100%);
  border-color: rgba(71, 85, 105, 0.4);
}

.dark .stat-value {
  color: #a5b4fc;
}

.dark .letter-key {
  background: linear-gradient(145deg, #334155 0%, #1e293b 100%);
  border-color: #475569;
  color: #e2e8f0;
}

.dark .letter-key:active {
  background-color: #475569;
  border-color: #60a5fa;
}

.dark .letter-key.found {
  background: linear-gradient(145deg, #22c55e 0%, #4ade80 100%);
  border-color: #16a34a;
  color: white;
}

.dark .letter-key.not-found {
  background: linear-gradient(145deg, #ef4444 0%, #f87171 100%);
  border-color: #dc2626;
  color: white;
}

.dark .progress-fill {
  background: linear-gradient(90deg, #6366F1, #818CF8, #A78BFA);
  box-shadow: 0 0 20rpx rgba(99, 102, 241, 0.5);
}

.dark .quiz-card {
  background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
  border-color: #475569;
}

.dark .quiz-card-title {
  color: #f1f5f9;
}

.dark .mode-btn,
.dark .difficulty-btn {
  background-color: #1e293b;
  border-color: #475569;
  color: #cbd5e1;
}

.dark .mode-btn:active,
.dark .difficulty-btn:active {
  background-color: #334155;
}

.dark .mode-btn.active {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-light) 100%);
  color: white;
}

.dark .difficulty-btn.active {
  background: linear-gradient(135deg, #059669 0%, #10b981 100%);
  color: white;
}

.dark .clay-input {
  background: var(--input-bg);
  border-color: rgba(71, 85, 105, 0.5);
  color: #e2e8f0;
}

.dark .clay-card {
  background: var(--clay-bg);
  border-color: rgba(71, 85, 105, 0.4);
  box-shadow: var(--clay-shadow);
}

.dark .clay-btn {
  background: var(--btn-bg);
  border-color: rgba(71, 85, 105, 0.5);
  color: #e2e8f0;
}

.dark .text-slate-500 {
  color: #94a3b8;
}

.dark .text-slate-600 {
  color: #94a3b8;
}

.dark .text-slate-700 {
  color: #cbd5e1;
}

.dark .text-slate-800 {
  color: #e2e8f0;
}

.dark .text-slate-900 {
  color: #f1f5f9;
}

.dark .empty-state {
  color: #94a3b8;
}

.dark .empty-state-title {
  color: #cbd5e1;
}
