.container {
  min-height: 100vh;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.header {
  margin-bottom: 24rpx;
}

.form-section {
  margin-bottom: 24rpx;
}

.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-color);
  margin-bottom: 12rpx;
}

.form-hint {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-top: 8rpx;
}

.textarea {
  min-height: 160rpx;
  padding-top: 20rpx;
  padding-bottom: 20rpx;
}

.picker-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: var(--input-bg);
  border: var(--input-border);
  border-radius: var(--input-radius);
  box-shadow: var(--input-shadow);
  font-size: 30rpx;
  color: var(--text-color);
}

.picker-arrow {
  font-size: 24rpx;
  color: #64748b;
}

.station-select-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.info-text {
  font-size: 26rpx;
  color: var(--primary-color);
  font-weight: 600;
}

.info-hint {
  font-size: 24rpx;
  color: #64748b;
}

.select-btn {
  width: 100%;
}

.selected-stations {
  margin-top: 16rpx;
  max-height: 400rpx;
  overflow-y: auto;
}

.selected-station-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  background: rgba(129, 140, 248, 0.1);
  border: 2rpx solid rgba(129, 140, 248, 0.2);
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.station-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.station-cn {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-color);
}

.station-en {
  font-size: 24rpx;
  color: #64748b;
}

.remove-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(239, 68, 68, 0.1);
  border-radius: 50%;
}

.remove-icon {
  font-size: 24rpx;
  color: var(--error-color);
}

.difficulty-options {
  display: flex;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.difficulty-info {
  margin-top: 8rpx;
}

.checkbox-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: white;
  border: 4rpx solid rgba(129, 140, 248, 0.3);
  border-radius: 12rpx;
}

.checkbox.checked {
  background: var(--primary-color);
  border-color: var(--primary-color);
}

.check-icon {
  font-size: 28rpx;
  color: white;
  font-weight: 700;
}

.checkbox-label {
  font-size: 28rpx;
  color: var(--text-color);
}

.mt-2 {
  margin-top: 16rpx;
}

.action-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.create-btn, .cancel-btn {
  width: 100%;
}

.station-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.station-modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  max-height: 80vh;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.98) 0%, rgba(248, 250, 252, 0.95) 100%);
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.station-modal.show .modal-content {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid rgba(129, 140, 248, 0.2);
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-color);
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(129, 140, 248, 0.1);
  border-radius: 50%;
}

.close-icon {
  font-size: 28rpx;
  color: #64748b;
}

.modal-search {
  padding: 24rpx 32rpx;
}

.search-input {
  width: 100%;
}

.station-list {
  flex: 1;
  padding: 0 32rpx;
  max-height: 50vh;
}

.station-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(129, 140, 248, 0.2);
  border-radius: 20rpx;
  margin-bottom: 16rpx;
}

.station-item.selected {
  background: rgba(129, 140, 248, 0.1);
  border-color: var(--primary-color);
}

.station-item-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.station-item-cn {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-color);
}

.station-item-en {
  font-size: 24rpx;
  color: #64748b;
}

.station-item-city {
  font-size: 22rpx;
  color: var(--primary-color);
}

.station-item-check {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--primary-color);
  border-radius: 50%;
}

.station-item-check .check-icon {
  font-size: 26rpx;
}

.modal-footer {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid rgba(129, 140, 248, 0.2);
}

.confirm-btn {
  width: 100%;
}

.dark .picker-value {
  background: linear-gradient(145deg, #334155 0%, #1e293b 100%);
  border-color: rgba(71, 85, 105, 0.5);
  color: #e2e8f0;
}

.dark .selected-station-item {
  background: rgba(79, 70, 229, 0.2);
  border-color: rgba(79, 70, 229, 0.3);
}

.dark .station-cn {
  color: #f1f5f9;
}

.dark .station-en {
  color: #94a3b8;
}

.dark .checkbox {
  background: #1e293b;
  border-color: rgba(71, 85, 105, 0.5);
}

.dark .checkbox.checked {
  background: var(--primary-color);
  border-color: var(--primary-color);
}

.dark .checkbox-label {
  color: #e2e8f0;
}

.dark .modal-content {
  background: linear-gradient(145deg, rgba(30, 41, 59, 0.98) 0%, rgba(15, 23, 42, 0.95) 100%);
}

.dark .modal-header {
  border-bottom-color: rgba(71, 85, 105, 0.4);
}

.dark .modal-title {
  color: #f1f5f9;
}

.dark .station-item {
  background: rgba(30, 41, 59, 0.9);
  border-color: rgba(71, 85, 105, 0.4);
}

.dark .station-item.selected {
  background: rgba(79, 70, 229, 0.2);
  border-color: var(--primary-color);
}

.dark .station-item-cn {
  color: #f1f5f9;
}

.dark .station-item-en {
  color: #94a3b8;
}

.dark .modal-footer {
  border-top-color: rgba(71, 85, 105, 0.4);
}
