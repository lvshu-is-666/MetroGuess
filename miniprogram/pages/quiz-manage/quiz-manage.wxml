<view class="container {{theme}}">
  <view class="header">
    <text class="page-title">管理题组</text>
  </view>

  <view wx:if="{{!loggedIn}}" class="login-section">
    <view class="clay-card">
      <text class="section-title">登录管理</text>
      <text class="section-desc">请输入题组ID和管理凭证来管理题组</text>

      <view class="form-group">
        <text class="form-label">题组ID</text>
        <input 
          class="clay-input" 
          type="text" 
          placeholder="输入题组ID" 
          value="{{loginQuizId}}"
          bindinput="onQuizIdInput"
          maxlength="20"
        />
      </view>

      <view class="form-group">
        <text class="form-label">管理用户名</text>
        <input 
          class="clay-input" 
          type="text" 
          placeholder="输入管理用户名" 
          value="{{loginUsername}}"
          bindinput="onUsernameInput"
          maxlength="30"
        />
      </view>

      <view class="form-group">
        <text class="form-label">管理密码</text>
        <input 
          class="clay-input" 
          type="password" 
          placeholder="输入管理密码" 
          value="{{loginPassword}}"
          bindinput="onPasswordInput"
          maxlength="30"
        />
      </view>

      <button class="btn-primary login-btn" bindtap="login">登录</button>
    </view>
  </view>

  <view wx:if="{{loggedIn && quiz}}" class="manage-section">
    <view class="clay-card quiz-info-card">
      <view class="quiz-header">
        <text class="quiz-name">{{quiz.name}}</text>
        <text class="quiz-id">ID: {{quiz.id}}</text>
      </view>
      <view class="quiz-meta">
        <text class="quiz-tag {{'quiz-tag-difficulty-' + quiz.difficultyLevel}}">
          {{getDifficultyLabel(quiz.difficultyLevel)}}
        </text>
        <text class="quiz-tag quiz-tag-count">{{quiz.questions.length}}题</text>
        <text class="quiz-tag quiz-tag-city">{{quiz.cityScope || '全国'}}</text>
      </view>
      <view class="quiz-stats">
        <view class="stat-item">
          <text class="stat-icon">🎮</text>
          <text class="stat-text">{{quiz.playCount || 0}}次游玩</text>
        </view>
        <view class="stat-item">
          <text class="stat-icon">📅</text>
          <text class="stat-text">{{formatTime(quiz.createdAt)}}</text>
        </view>
      </view>
    </view>

    <view class="clay-card">
      <text class="section-title">题组设置</text>

      <view class="form-group">
        <text class="form-label">题组名称</text>
        <input 
          class="clay-input" 
          type="text" 
          placeholder="题组名称" 
          value="{{editName}}"
          bindinput="onEditNameInput"
          maxlength="50"
        />
      </view>

      <view class="form-group">
        <text class="form-label">题组描述</text>
        <textarea 
          class="clay-input textarea" 
          placeholder="题组描述" 
          value="{{editDescription}}"
          bindinput="onEditDescriptionInput"
          maxlength="200"
        />
      </view>

      <view class="form-group">
        <view class="checkbox-row" bindtap="toggleEditPublic">
          <view class="checkbox {{editIsPublic ? 'checked' : ''}}">
            <text wx:if="{{editIsPublic}}" class="check-icon">✓</text>
          </view>
          <text class="checkbox-label">公开题组</text>
        </view>
      </view>

      <view class="form-group">
        <view class="checkbox-row" bindtap="toggleEditHideTheme">
          <view class="checkbox {{editHideTheme ? 'checked' : ''}}">
            <text wx:if="{{editHideTheme}}" class="check-icon">✓</text>
          </view>
          <text class="checkbox-label">隐藏题组名称</text>
        </view>
      </view>

      <view class="form-group">
        <text class="form-label">邀请码</text>
        <input 
          class="clay-input" 
          type="text" 
          placeholder="邀请码（留空则无需邀请码）" 
          value="{{editInviteCode}}"
          bindinput="onEditInviteCodeInput"
          maxlength="20"
        />
      </view>

      <button class="btn-primary save-btn" bindtap="saveChanges">保存修改</button>
    </view>

    <view class="clay-card">
      <text class="section-title">分享题组</text>
      <view class="share-section">
        <view class="share-info">
          <text class="share-label">题组ID:</text>
          <text class="share-value">{{quiz.id}}</text>
        </view>
        <button class="btn-secondary copy-btn" bindtap="copyQuizId">复制ID</button>
      </view>
      <button class="btn-secondary share-btn" bindtap="shareQuiz">分享题组</button>
    </view>

    <view class="clay-card danger-card">
      <text class="section-title danger-title">危险操作</text>
      <button class="btn-danger delete-btn" bindtap="deleteQuiz">删除题组</button>
      <text class="danger-hint">删除后无法恢复，请谨慎操作</text>
    </view>

    <button class="btn-secondary logout-btn" bindtap="logout">退出登录</button>
  </view>
</view>
