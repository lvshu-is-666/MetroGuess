.container {
  min-height: 100vh;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.loading-section, .error-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #64748b;
}

.error-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.error-title {
  font-size: 32rpx;
  color: var(--text-color);
  margin-bottom: 32rpx;
}

.invite-section {
  animation: fadeInUp 0.5s ease-out;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-color);
  margin-bottom: 12rpx;
  display: block;
}

.section-desc {
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 24rpx;
  display: block;
}

.welcome-section {
  animation: fadeInUp 0.5s ease-out;
}

.quiz-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-color);
  margin-bottom: 16rpx;
  display: block;
  text-align: center;
}

.quiz-meta {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.quiz-description {
  margin-bottom: 16rpx;
  padding: 16rpx;
  background: rgba(129, 140, 248, 0.1);
  border-radius: 16rpx;
}

.description-text {
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.5;
}

.quiz-stats {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stat-icon {
  font-size: 28rpx;
}

.stat-text {
  font-size: 26rpx;
  color: #64748b;
}

.mt-4 {
  margin-top: 32rpx;
}

.difficulty-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.difficulty-info {
  display: flex;
  gap: 32rpx;
  margin-bottom: 32rpx;
}

.info-text {
  font-size: 26rpx;
  color: #64748b;
}

.start-btn {
  width: 100%;
}

.game-section {
  animation: fadeInUp 0.5s ease-out;
}

.stats-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stats-row .stat-box {
  flex: 1;
  padding: 16rpx 12rpx;
}

.stats-row .stat-value {
  font-size: 36rpx;
}

.stats-row .stat-label {
  font-size: 22rpx;
}

.progress-container {
  margin-bottom: 24rpx;
}

.stations-container {
  margin-bottom: 24rpx;
}

.station-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.station-number {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.solved-badge {
  font-size: 22rpx;
  color: var(--success-color);
  font-weight: 600;
}

.station-display {
  margin: 16rpx 0;
}

.station-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 2rpx solid rgba(129, 140, 248, 0.2);
}

.station-cn {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--success-color);
}

.station-en {
  font-size: 26rpx;
  color: #64748b;
}

.letter-solved {
  color: var(--success-color);
}

.keyboard-section {
  margin-bottom: 24rpx;
}

.keyboard-row {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
}

.action-buttons {
  margin-bottom: 24rpx;
}

.guess-section {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.guess-input {
  flex: 1;
}

.guess-btn {
  min-width: 160rpx;
}

.result-section {
  animation: fadeInUp 0.5s ease-out;
}

.result-card {
  text-align: center;
}

.result-title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--success-color);
  margin-bottom: 32rpx;
  display: block;
}

.result-stats {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  margin-bottom: 32rpx;
}

.result-stat {
  text-align: center;
}

.result-value {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--primary-color);
  display: block;
}

.result-label {
  font-size: 26rpx;
  color: #64748b;
  margin-top: 8rpx;
  display: block;
}

.result-buttons {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.dark .quiz-title {
  color: #f1f5f9;
}

.dark .description-text {
  color: #94a3b8;
}

.dark .stat-text {
  color: #94a3b8;
}

.dark .result-title {
  color: #4ade80;
}

.dark .result-value {
  color: #a5b4fc;
}

.dark .result-label {
  color: #94a3b8;
}
