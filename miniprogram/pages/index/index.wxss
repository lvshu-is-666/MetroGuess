.container {
  min-height: 100vh;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.header {
  margin-bottom: 32rpx;
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-btns {
  display: flex;
  gap: 16rpx;
}

.theme-btn, .sound-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #ffffff 0%, #f1f5f9 100%);
  border: 4rpx solid rgba(129, 140, 248, 0.3);
  border-radius: 50%;
  box-shadow: 0 4rpx 0 rgba(129, 140, 248, 0.2), 0 8rpx 24rpx rgba(79, 70, 229, 0.1);
}

.theme-icon, .sound-icon {
  font-size: 36rpx;
}

.welcome-section {
  animation: fadeInUp 0.5s ease-out;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-color);
  margin-bottom: 24rpx;
  display: block;
}

.section-subtitle {
  font-size: 28rpx;
  font-weight: 600;
  color: #64748b;
  margin-bottom: 16rpx;
  display: block;
}

.mode-buttons, .difficulty-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.city-select-section {
  margin-bottom: 24rpx;
}

.picker-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: var(--input-bg);
  border: var(--input-border);
  border-radius: var(--input-radius);
  box-shadow: var(--input-shadow);
  font-size: 30rpx;
  color: var(--text-color);
}

.picker-arrow {
  font-size: 24rpx;
  color: #64748b;
}

.difficulty-info {
  display: flex;
  gap: 32rpx;
  margin-bottom: 32rpx;
}

.info-text {
  font-size: 26rpx;
  color: #64748b;
}

.start-btn {
  width: 100%;
  margin-top: 16rpx;
}

.game-section {
  animation: fadeInUp 0.5s ease-out;
}

.stats-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stats-row .stat-box {
  flex: 1;
  padding: 16rpx 12rpx;
}

.stats-row .stat-value {
  font-size: 36rpx;
}

.stats-row .stat-label {
  font-size: 22rpx;
}

.progress-container {
  margin-bottom: 24rpx;
}

.stations-container {
  margin-bottom: 24rpx;
}

.station-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.station-number {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.solved-badge {
  font-size: 22rpx;
  color: var(--success-color);
  font-weight: 600;
}

.station-display {
  margin: 16rpx 0;
}

.station-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 2rpx solid rgba(129, 140, 248, 0.2);
}

.station-cn {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--success-color);
}

.station-en {
  font-size: 26rpx;
  color: #64748b;
}

.letter-solved {
  color: var(--success-color);
}

.keyboard-section {
  margin-bottom: 24rpx;
}

.keyboard-row {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
}

.action-buttons {
  margin-bottom: 24rpx;
}

.guess-section {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.guess-input {
  flex: 1;
}

.guess-btn {
  min-width: 160rpx;
}

.history-section {
  margin-top: 24rpx;
}

.history-list {
  max-height: 300rpx;
  margin-top: 16rpx;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.9) 0%, rgba(248, 250, 252, 0.8) 100%);
  border: 2rpx solid rgba(129, 140, 248, 0.15);
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.history-item.correct {
  background: linear-gradient(145deg, rgba(220, 252, 231, 0.9) 0%, rgba(187, 247, 208, 0.8) 100%);
  border-color: rgba(74, 222, 128, 0.3);
}

.history-item.wrong {
  background: linear-gradient(145deg, rgba(254, 226, 226, 0.9) 0%, rgba(254, 202, 202, 0.8) 100%);
  border-color: rgba(252, 165, 165, 0.3);
}

.history-guess {
  font-size: 28rpx;
  color: var(--text-color);
}

.history-result {
  font-size: 24rpx;
  font-weight: 600;
}

.history-item.correct .history-result {
  color: var(--success-color);
}

.history-item.wrong .history-result {
  color: var(--error-color);
}

.result-section {
  animation: fadeInUp 0.5s ease-out;
}

.result-card {
  text-align: center;
}

.result-title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--success-color);
  margin-bottom: 32rpx;
  display: block;
}

.result-stats {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  margin-bottom: 32rpx;
}

.result-stat {
  text-align: center;
}

.result-value {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--primary-color);
  display: block;
}

.result-label {
  font-size: 26rpx;
  color: #64748b;
  margin-top: 8rpx;
  display: block;
}

.result-buttons {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.mt-4 {
  margin-top: 32rpx;
}

.dark .theme-btn, .dark .sound-btn {
  background: linear-gradient(145deg, #334155 0%, #1e293b 100%);
  border-color: rgba(71, 85, 105, 0.5);
}

.dark .picker-value {
  background: linear-gradient(145deg, #334155 0%, #1e293b 100%);
  border-color: rgba(71, 85, 105, 0.5);
  color: #e2e8f0;
}

.dark .history-item {
  background: linear-gradient(145deg, rgba(51, 65, 85, 0.9) 0%, rgba(30, 41, 59, 0.8) 100%);
}

.dark .history-item.correct {
  background: linear-gradient(145deg, rgba(34, 197, 94, 0.2) 0%, rgba(34, 197, 94, 0.1) 100%);
}

.dark .history-item.wrong {
  background: linear-gradient(145deg, rgba(239, 68, 68, 0.2) 0%, rgba(239, 68, 68, 0.1) 100%);
}

.dark .result-title {
  color: #4ade80;
}

.dark .result-value {
  color: #a5b4fc;
}
