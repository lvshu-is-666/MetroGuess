<view class="container {{theme}}">
  <view class="header">
    <view class="title-row">
      <text class="page-title">地铁猜猜乐</text>
      <view class="header-btns">
        <view class="theme-btn" bindtap="toggleTheme">
          <text class="theme-icon">{{theme === 'dark' ? '☀️' : '🌙'}}</text>
        </view>
        <view class="sound-btn" bindtap="toggleSound">
          <text class="sound-icon">{{soundEnabled ? '🔊' : '🔇'}}</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{!gameStarted}}" class="welcome-section">
    <view class="clay-card">
      <text class="section-title">选择游戏模式</text>
      <view class="mode-buttons">
        <view 
          class="mode-btn {{gameMode === 'city' ? 'active' : ''}}" 
          bindtap="selectMode" 
          data-mode="city">
          城市模式
        </view>
        <view 
          class="mode-btn {{gameMode === 'random' ? 'active' : ''}}" 
          bindtap="selectMode" 
          data-mode="random">
          随机模式
        </view>
      </view>

      <view wx:if="{{gameMode === 'city'}}" class="city-select-section">
        <text class="section-subtitle">选择城市</text>
        <picker 
          mode="selector" 
          range="{{cities}}" 
          value="{{selectedCityIndex}}" 
          bindchange="onCityChange">
          <view class="picker-value">
            {{cities[selectedCityIndex] || '请选择城市'}}
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>

      <text class="section-title mt-4">选择难度</text>
      <view class="difficulty-buttons">
        <view 
          class="difficulty-btn {{difficulty === 'easy' ? 'active' : ''}}" 
          bindtap="selectDifficulty" 
          data-difficulty="easy">
          简单
        </view>
        <view 
          class="difficulty-btn {{difficulty === 'normal' ? 'active' : ''}}" 
          bindtap="selectDifficulty" 
          data-difficulty="normal">
          普通
        </view>
        <view 
          class="difficulty-btn {{difficulty === 'hard' ? 'active' : ''}}" 
          bindtap="selectDifficulty" 
          data-difficulty="hard">
          困难
        </view>
      </view>

      <view class="difficulty-info">
        <text class="info-text">站点数: {{difficultySettings.stationCount}}</text>
        <text class="info-text">提示次数: {{difficultySettings.hints}}</text>
      </view>

      <button class="btn-primary start-btn" bindtap="startGame">
        开始游戏
      </button>
    </view>
  </view>

  <view wx:if="{{gameStarted && !gameWon}}" class="game-section">
    <view class="stats-row">
      <view class="stat-box">
        <text class="stat-value">{{score}}</text>
        <text class="stat-label">分数</text>
      </view>
      <view class="stat-box">
        <text class="stat-value">{{formatTime(elapsedTime)}}</text>
        <text class="stat-label">时间</text>
      </view>
      <view class="stat-box">
        <text class="stat-value">{{solvedCount}}/{{stations.length}}</text>
        <text class="stat-label">进度</text>
      </view>
      <view class="stat-box">
        <text class="stat-value">{{hintsLeft}}</text>
        <text class="stat-label">提示</text>
      </view>
    </view>

    <view class="progress-container">
      <view class="progress-fill" style="width: {{progress}}%;"></view>
    </view>

    <view class="stations-container">
      <view 
        wx:for="{{stations}}" 
        wx:key="index" 
        class="game-card {{item.solved ? 'solved' : ''}}">
        <view class="station-header">
          <text class="station-number">#{{item.index + 1}}</text>
          <text wx:if="{{item.solved}}" class="solved-badge">✓ 已解决</text>
        </view>
        <view class="station-display">
          <text class="letter-display">
            <text wx:for="{{item.displayText}}" wx:key="index" wx:for-item="char" class="{{char.revealed ? 'letter-reveal' : ''}} {{char.solved ? 'letter-solved' : ''}}">{{char.char}}</text>
          </text>
        </view>
        <view wx:if="{{item.solved}}" class="station-info">
          <text class="station-cn">{{item.station_cn}}</text>
          <text class="station-en">{{item.station_en}}</text>
        </view>
      </view>
    </view>

    <view class="keyboard-section">
      <view class="keyboard-row" wx:for="{{keyboardRows}}" wx:key="index">
        <view 
          wx:for="{{item}}" 
          wx:key="*this" 
          class="letter-key {{usedLetters.indexOf(item.toLowerCase()) > -1 ? (foundLetters.indexOf(item.toLowerCase()) > -1 ? 'found' : 'not-found') : ''}} {{usedLetters.indexOf(item.toLowerCase()) > -1 ? 'used' : ''}}"
          bindtap="revealLetter"
          data-letter="{{item}}">
          {{item}}
        </view>
      </view>
    </view>

    <view class="action-buttons">
      <button class="btn-hint" bindtap="useHint" disabled="{{hintsLeft <= 0}}">
        使用提示 ({{hintsLeft}})
      </button>
    </view>

    <view class="guess-section">
      <input 
        class="clay-input guess-input" 
        type="text" 
        placeholder="输入站名猜测..." 
        value="{{guessInput}}"
        bindinput="onGuessInput"
        confirm-type="done"
        bindconfirm="submitGuess"
      />
      <button class="btn-secondary guess-btn" bindtap="submitGuess">
        猜测
      </button>
    </view>

    <view wx:if="{{guessHistory.length > 0}}" class="history-section">
      <text class="section-subtitle">猜测记录</text>
      <scroll-view scroll-y class="history-list">
        <view 
          wx:for="{{guessHistory}}" 
          wx:key="index" 
          class="history-item {{item.correct ? 'correct' : 'wrong'}}">
          <text class="history-guess">{{item.guess}}</text>
          <text class="history-result">{{item.correct ? '✓ 正确' : '✗ 错误'}}</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <view wx:if="{{gameWon}}" class="result-section">
    <view class="clay-card result-card">
      <text class="result-title">🎉 恭喜通关！</text>
      <view class="result-stats">
        <view class="result-stat">
          <text class="result-value">{{finalScore}}</text>
          <text class="result-label">最终得分</text>
        </view>
        <view class="result-stat">
          <text class="result-value">{{formatTime(elapsedTime)}}</text>
          <text class="result-label">用时</text>
        </view>
        <view class="result-stat">
          <text class="result-value">{{guessCount}}</text>
          <text class="result-label">猜测次数</text>
        </view>
      </view>
      <view class="result-buttons">
        <button class="btn-primary" bindtap="restartGame">再玩一次</button>
        <button class="btn-secondary" bindtap="backToMenu">返回菜单</button>
      </view>
    </view>
  </view>
</view>
