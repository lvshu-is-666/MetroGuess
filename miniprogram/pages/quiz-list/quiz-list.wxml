<view class="container {{theme}}">
  <view class="header">
    <view class="title-row">
      <text class="page-title">题组列表</text>
      <view class="header-btns">
        <view class="theme-btn" bindtap="toggleTheme">
          <text class="theme-icon">{{theme === 'dark' ? '☀️' : '🌙'}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="action-bar">
    <button class="btn-primary create-btn" bindtap="goToCreate">
      ➕ 创建题组
    </button>
    <button class="btn-secondary manage-btn" bindtap="goToManage">
      📋 管理题组
    </button>
  </view>

  <view class="filter-section">
    <view class="filter-row">
      <picker 
        mode="selector" 
        range="{{sortOptions}}" 
        range-key="label"
        value="{{sortIndex}}" 
        bindchange="onSortChange">
        <view class="filter-select">
          {{sortOptions[sortIndex].label}}
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
      <picker 
        mode="selector" 
        range="{{difficultyOptions}}" 
        range-key="label"
        value="{{difficultyIndex}}" 
        bindchange="onDifficultyChange">
        <view class="filter-select">
          {{difficultyOptions[difficultyIndex].label}}
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading-section">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <view wx:elif="{{quizzes.length === 0}}" class="empty-state">
    <text class="empty-icon">📝</text>
    <text class="empty-title">暂无题组</text>
    <text class="empty-desc">快来创建第一个题组吧！</text>
    <button class="btn-primary" bindtap="goToCreate">创建题组</button>
  </view>

  <view wx:else class="quiz-list">
    <view 
      wx:for="{{quizzes}}" 
      wx:key="id" 
      class="quiz-card"
      bindtap="goToPlay"
      data-id="{{item.id}}">
      <view class="quiz-card-header">
        <text class="quiz-card-title">{{item.hideTheme ? '神秘题组' : item.name}}</text>
        <view wx:if="{{item.featured}}" class="featured-badge">
          <text class="featured-icon">⭐</text>
          <text class="featured-text">精选</text>
        </view>
      </view>
      <view class="quiz-card-meta">
        <text class="quiz-tag {{'quiz-tag-difficulty-' + item.difficultyLevel}}">
          {{getDifficultyLabel(item.difficultyLevel)}}
        </text>
        <text class="quiz-tag quiz-tag-city">{{item.cityScope || '全国'}}</text>
        <text class="quiz-tag quiz-tag-count">{{item.questions.length}}题</text>
      </view>
      <view class="quiz-stats">
        <view class="quiz-stat-item">
          <text class="stat-icon">🎮</text>
          <text class="stat-text">{{item.playCount || 0}}次游玩</text>
        </view>
        <view class="quiz-stat-item">
          <text class="stat-icon">📅</text>
          <text class="stat-text">{{formatTimeAgo(item.createdAt)}}</text>
        </view>
      </view>
      <view wx:if="{{item.description}}" class="quiz-description">
        <text class="description-text">{{item.description}}</text>
      </view>
    </view>
  </view>

  <view class="load-more" wx:if="{{hasMore && !loading}}">
    <button class="clay-btn" bindtap="loadMore">加载更多</button>
  </view>
</view>
