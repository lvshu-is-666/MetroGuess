.container {
  min-height: 100vh;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.header {
  margin-bottom: 24rpx;
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-btns {
  display: flex;
  gap: 16rpx;
}

.theme-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #ffffff 0%, #f1f5f9 100%);
  border: 4rpx solid rgba(129, 140, 248, 0.3);
  border-radius: 50%;
  box-shadow: 0 4rpx 0 rgba(129, 140, 248, 0.2), 0 8rpx 24rpx rgba(79, 70, 229, 0.1);
}

.theme-icon {
  font-size: 36rpx;
}

.action-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.create-btn, .manage-btn {
  flex: 1;
}

.filter-section {
  margin-bottom: 24rpx;
}

.filter-row {
  display: flex;
  gap: 16rpx;
}

.filter-select {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: linear-gradient(145deg, #ffffff 0%, #f8fafc 100%);
  border: 4rpx solid rgba(129, 140, 248, 0.25);
  border-radius: 20rpx;
  font-size: 28rpx;
  color: var(--text-color);
}

.picker-arrow {
  font-size: 20rpx;
  color: #64748b;
}

.loading-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 96rpx 0;
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #64748b;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 96rpx 48rpx;
  text-align: center;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #475569;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #64748b;
  margin-bottom: 32rpx;
}

.quiz-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.quiz-card {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.98) 0%, rgba(238, 242, 255, 0.95) 100%);
  border: 4rpx solid rgba(129, 140, 248, 0.4);
  border-radius: 32rpx;
  padding: 28rpx;
  transition: all 0.25s ease;
}

.quiz-card:active {
  transform: scale(0.98);
  border-color: var(--primary-light);
  box-shadow: 0 16rpx 64rpx rgba(79, 70, 229, 0.2);
}

.quiz-card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.quiz-card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1e293b;
  flex: 1;
}

.featured-badge {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  border-radius: 9999rpx;
}

.featured-icon {
  font-size: 22rpx;
}

.featured-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #92400e;
}

.quiz-card-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.quiz-stats {
  display: flex;
  gap: 32rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid rgba(129, 140, 248, 0.2);
}

.quiz-stat-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stat-icon {
  font-size: 28rpx;
}

.stat-text {
  font-size: 26rpx;
  color: #64748b;
}

.quiz-description {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid rgba(129, 140, 248, 0.2);
}

.description-text {
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.5;
}

.load-more {
  display: flex;
  justify-content: center;
  padding: 32rpx 0;
}

.dark .filter-select {
  background: linear-gradient(145deg, #334155 0%, #1e293b 100%);
  border-color: rgba(71, 85, 105, 0.5);
  color: #e2e8f0;
}

.dark .quiz-card {
  background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
  border-color: #475569;
}

.dark .quiz-card-title {
  color: #f1f5f9;
}

.dark .quiz-stats {
  border-top-color: rgba(71, 85, 105, 0.4);
}

.dark .stat-text {
  color: #94a3b8;
}

.dark .quiz-description {
  border-top-color: rgba(71, 85, 105, 0.4);
}

.dark .description-text {
  color: #94a3b8;
}

.dark .empty-title {
  color: #cbd5e1;
}

.dark .empty-desc {
  color: #94a3b8;
}
