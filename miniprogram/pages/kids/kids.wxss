.container {
  min-height: 100vh;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.header {
  margin-bottom: 32rpx;
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-btns {
  display: flex;
  gap: 16rpx;
}

.theme-btn, .sound-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #ffffff 0%, #f1f5f9 100%);
  border: 4rpx solid rgba(129, 140, 248, 0.3);
  border-radius: 50%;
  box-shadow: 0 4rpx 0 rgba(129, 140, 248, 0.2), 0 8rpx 24rpx rgba(79, 70, 229, 0.1);
}

.theme-icon, .sound-icon {
  font-size: 36rpx;
}

.kids-title {
  background: linear-gradient(135deg, #F97316 0%, #FB923C 50%, #FBBF24 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.welcome-section {
  animation: fadeInUp 0.5s ease-out;
}

.kids-card {
  text-align: center;
  background: linear-gradient(145deg, rgba(255, 251, 235, 0.95) 0%, rgba(254, 243, 199, 0.9) 100%);
  border-color: rgba(251, 191, 36, 0.3);
}

.kids-mascot {
  margin-bottom: 24rpx;
}

.mascot-emoji {
  font-size: 96rpx;
}

.kids-welcome {
  font-size: 40rpx;
  font-weight: 700;
  color: #F97316;
  margin-bottom: 16rpx;
  display: block;
}

.kids-desc {
  font-size: 28rpx;
  color: #92400e;
  margin-bottom: 32rpx;
  display: block;
}

.section-subtitle {
  font-size: 28rpx;
  font-weight: 600;
  color: #92400e;
  margin-bottom: 16rpx;
  display: block;
}

.city-select-section {
  margin-bottom: 32rpx;
}

.kids-picker {
  background: linear-gradient(145deg, #ffffff 0%, #fffbeb 100%);
  border-color: rgba(251, 191, 36, 0.3);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.city-emoji {
  font-size: 32rpx;
}

.kids-info {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-bottom: 32rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.info-emoji {
  font-size: 40rpx;
}

.info-text {
  font-size: 24rpx;
  color: #92400e;
  font-weight: 600;
}

.kids-start-btn {
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  box-shadow: 0 8rpx 24rpx rgba(249, 115, 22, 0.3);
}

.game-section {
  animation: fadeInUp 0.5s ease-out;
}

.kids-stats {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.kids-stat-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  background: linear-gradient(145deg, rgba(255, 251, 235, 0.9) 0%, rgba(254, 243, 199, 0.8) 100%);
  border: 4rpx solid rgba(251, 191, 36, 0.2);
  border-radius: 24rpx;
}

.kids-stat-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.kids-stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #F97316;
}

.kids-progress {
  position: relative;
  height: 40rpx;
  margin-bottom: 24rpx;
}

.progress-text {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  font-size: 22rpx;
  font-weight: 600;
  color: white;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.2);
}

.kids-station-card {
  background: linear-gradient(135deg, rgba(255, 251, 235, 0.95) 0%, rgba(254, 243, 199, 0.9) 100%);
  border-color: rgba(251, 191, 36, 0.3);
}

.kids-station-card.solved {
  background: linear-gradient(135deg, rgba(220, 252, 231, 0.95) 0%, rgba(187, 247, 208, 0.9) 100%);
  border-color: var(--success-color);
}

.kids-number {
  font-size: 28rpx;
  color: #F97316;
}

.kids-badge {
  font-size: 26rpx;
  color: var(--success-color);
}

.kids-letters {
  font-size: 40rpx;
}

.kids-cn {
  font-size: 36rpx;
  color: var(--success-color);
}

.kids-en {
  font-size: 28rpx;
}

.kids-key {
  width: 80rpx;
  height: 80rpx;
  font-size: 36rpx;
}

.kids-hint-btn {
  background: linear-gradient(135deg, #FBBF24 0%, #F59E0B 100%);
  box-shadow: 0 8rpx 24rpx rgba(251, 191, 36, 0.3);
}

.kids-input {
  background: linear-gradient(145deg, #ffffff 0%, #fffbeb 100%);
  border-color: rgba(251, 191, 36, 0.3);
}

.kids-guess-btn {
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  box-shadow: 0 8rpx 24rpx rgba(249, 115, 22, 0.3);
}

.result-section {
  animation: fadeInUp 0.5s ease-out;
}

.kids-result {
  background: linear-gradient(145deg, rgba(255, 251, 235, 0.98) 0%, rgba(254, 243, 199, 0.95) 100%);
  border-color: rgba(251, 191, 36, 0.3);
}

.result-celebration {
  margin-bottom: 24rpx;
}

.celebration-emoji {
  font-size: 64rpx;
  margin: 0 16rpx;
}

.kids-result-title {
  font-size: 56rpx;
  color: #F97316;
  margin-bottom: 8rpx;
}

.result-subtitle {
  font-size: 32rpx;
  color: #92400e;
  margin-bottom: 32rpx;
  display: block;
}

.result-stats {
  display: flex;
  justify-content: center;
  gap: 64rpx;
  margin-bottom: 32rpx;
}

.result-stat {
  text-align: center;
}

.result-emoji {
  font-size: 48rpx;
  display: block;
  margin-bottom: 8rpx;
}

.result-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #F97316;
  display: block;
}

.result-label {
  font-size: 26rpx;
  color: #92400e;
  margin-top: 4rpx;
  display: block;
}

.result-buttons {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.dark .kids-card {
  background: linear-gradient(145deg, rgba(30, 41, 59, 0.95) 0%, rgba(51, 65, 85, 0.9) 100%);
  border-color: rgba(71, 85, 105, 0.4);
}

.dark .kids-welcome {
  color: #FB923C;
}

.dark .kids-desc {
  color: #cbd5e1;
}

.dark .kids-picker {
  background: linear-gradient(145deg, #334155 0%, #1e293b 100%);
  border-color: rgba(71, 85, 105, 0.5);
  color: #e2e8f0;
}

.dark .info-text {
  color: #cbd5e1;
}

.dark .kids-stat-box {
  background: linear-gradient(145deg, rgba(51, 65, 85, 0.9) 0%, rgba(30, 41, 59, 0.8) 100%);
  border-color: rgba(71, 85, 105, 0.4);
}

.dark .kids-stat-value {
  color: #FB923C;
}

.dark .kids-station-card {
  background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
  border-color: #475569;
}

.dark .kids-station-card.solved {
  background: linear-gradient(135deg, #14532d 0%, #166534 100%);
  border-color: var(--success-color);
}

.dark .kids-number {
  color: #FB923C;
}

.dark .kids-result {
  background: linear-gradient(145deg, rgba(30, 41, 59, 0.98) 0%, rgba(15, 23, 42, 0.95) 100%);
  border-color: rgba(71, 85, 105, 0.4);
}

.dark .kids-result-title {
  color: #FB923C;
}

.dark .result-subtitle {
  color: #cbd5e1;
}

.dark .result-value {
  color: #FB923C;
}

.dark .result-label {
  color: #94a3b8;
}
