{
  "rules": {
    "rooms": {
      ".read": true,
      ".indexOn": ["status", "createdAt"],
      "$roomId": {
        ".write": true
      }
    },
    "users": {
      "$userId": {
        ".read": true,
        ".write": true
      }
    },
    "quizzes": {
      ".read": true,
      "$quizId": {
        ".write": true
      }
    },
    "quizLeaderboards": {
      "$quizId": {
        ".read": true,
        ".write": true
      }
    }
  }
}
